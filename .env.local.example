# Copy this file to .env.local and fill in your values
# Get these from https://supabase.com → your project → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Site URL (used for sitemap generation)
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ── AI Chat & Plant Diagnosis (Kie.ai API) ──────────────────────────────────
# Get your key from https://kie.ai/api-key
# Used for: AI strain chat (gemini-2.5-flash) + plant diagnosis (vision)
KIE_API_KEY=your-kie-api-key-here

# ── PayPal (Pro subscriptions) ───────────────────────────────────────────────
# Get from https://developer.paypal.com → My Apps & Credentials
# Use Sandbox credentials for testing, Live for production
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id-here
PAYPAL_CLIENT_SECRET=your-paypal-client-secret-here

